# The Anthropic API key used for relevance scoring.
# This lives on the server only and is never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: change the scoring model. Defaults to Haiku, which is
# fast and cheap and fine for short relevance judgments. Switch to
# claude-sonnet-4-6 if you want sharper scoring at higher cost.
# SLATE_MODEL=claude-haiku-4-5-20251001
