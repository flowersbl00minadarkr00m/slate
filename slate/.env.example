# The OpenAI API key used for relevance scoring.
# This lives on the server only and is never sent to the browser.
OPENAI_API_KEY=sk-your-key-here

# Optional: change the scoring model.
SLATE_MODEL=gpt-5.5

# Server-side YouTube search. Restrict this key to YouTube Data API v3
# and to your deployment domains in Google Cloud.
YOUTUBE_API_KEY=AIza-your-key-here

# Optional Supabase cache/persistence. These are server-only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
POSTGRES_URL_NON_POOLING=postgresql://...
